# ── Servidor ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=*

# ── Oracle (TypeORM) ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=1521
DB_SID=ORCL
DB_USERNAME=ac
DB_PASSWORD=secret
DB_SCHEMA=AC

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── API Key (frontend / sistemas internos) ────────────────────
API_KEY_FRONTEND=dev-frontend-key

# ── Módulo Firma (microservicio externo) ──────────────────────
# URL base del firma-accionistas-backend
FIRMA_SERVICE_URL=http://localhost:3002
# API Key con rol "Core" del microservicio de firma
FIRMA_CORE_API_KEY=dev-core-key

# ── Parámetros de negocio ─────────────────────────────────────
# Meses máximos de vigencia del accionista (ac_fnc_meses_vencimiento_act)
# En producción se puede también leer de ACC_PARAMETROS_GENERALES.MESES_ACT_ACC
MESES_VIGENCIA_ACCIONISTA=18

# ── Lock timeout ──────────────────────────────────────────────
# Tiempo máximo en ms que espera una transacción para obtener el lock
# de la tabla ACC_EXPEDIENTES_ASAMBLEA (SELECT FOR UPDATE)
DB_LOCK_TIMEOUT_MS=10000
